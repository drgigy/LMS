rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function enrollmentId(courseId) {
      return request.auth.uid + "_" + courseId;
    }

    function hasActiveEnrollment(courseId) {
      return signedIn()
        && exists(/databases/$(database)/documents/enrollments/$(enrollmentId(courseId)))
        && get(/databases/$(database)/documents/enrollments/$(enrollmentId(courseId))).data.status == "active";
    }

    match /progress/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /enrollments/{enrollmentDoc} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /videoMap/{courseId} {
      allow read: if hasActiveEnrollment(courseId) || isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
